<?php

$nome = "   beatriz barros   ";

$nome = trim($nome);          // remove espaços
$nome = strtoupper($nome);    // deixa maiúsculo

$quantidade = strlen($nome);

echo "Nome formatado: " . $nome . "<br>";
echo "Quantidade de caracteres: " . $quantidade;

